---
import Layout from "../layouts/Layout.astro";
import Logo from "../components/Logo.astro";
import Icon from "../components/Icon.astro";
import { site } from "../config";
---

<Layout
  title="Thanks — Ad-Ascent"
  description="Your message has been received. We'll be in touch shortly."
>
  <main id="main" class="grid min-h-screen place-items-center px-6 py-20">
    <div class="w-full max-w-md text-center">
      <a href="/#home" class="mb-10 inline-flex" aria-label="Ad-Ascent home">
        <Logo />
      </a>

      <div id="ok-state" class="rounded-[var(--radius-lg)] border border-border bg-surface/50 p-8">
        <span class="mx-auto grid h-14 w-14 place-items-center rounded-full bg-success/15 text-success">
          <Icon name="check" class="h-7 w-7" />
        </span>
        <h1 class="mt-6 text-2xl font-extrabold tracking-tight">Message received</h1>
        <p class="mt-3 text-sm leading-relaxed text-muted">
          Thanks for reaching out. We'll review your details and get back to you shortly with a
          clear plan to turn more searches into booked jobs.
        </p>
      </div>

      <!-- Shown instead only when the server redirects with ?error=1 (needs JS). -->
      <div
        id="error-state"
        class="hidden rounded-[var(--radius-lg)] border border-danger/40 bg-danger/10 p-8"
      >
        <h1 class="text-2xl font-extrabold tracking-tight">Something went wrong</h1>
        <p class="mt-3 text-sm leading-relaxed text-muted">
          We couldn't process your message. Please email us directly at
          <a href={`mailto:${site.contactEmail}`} class="font-semibold text-primary">{site.contactEmail}</a>
          and we'll take it from there.
        </p>
      </div>

      <a
        href="/#home"
        class="mt-8 inline-flex items-center gap-2 rounded-full border border-border bg-surface/60 px-5 py-2.5 text-sm font-semibold text-text transition-colors hover:border-primary/50"
      >
        <Icon name="arrow" class="h-4 w-4 rotate-180" />
        Back to home
      </a>
    </div>
  </main>

  <script>
    if (new URLSearchParams(location.search).get("error") === "1") {
      document.getElementById("ok-state")?.classList.add("hidden");
      document.getElementById("error-state")?.classList.remove("hidden");
    }
  </script>
</Layout>
