---
import { whatsappHref } from "../config";
---

<a
  href={whatsappHref}
  target="_blank"
  rel="noopener noreferrer"
  id="whatsapp-fab"
  aria-label="Chat with Ad-Ascent on WhatsApp"
  class="group fixed bottom-5 right-5 z-40 grid h-14 w-14 translate-y-4 place-items-center rounded-full bg-[#25D366] opacity-0 shadow-[0_10px_30px_-8px_rgba(37,211,102,0.5)] transition-[opacity,transform] duration-500 hover:scale-105 focus-visible:opacity-100 sm:bottom-6 sm:right-6"
  data-fab
>
  <!-- gentle pulse ring -->
  <span
    class="absolute inset-0 -z-10 rounded-full bg-[#25D366] opacity-60 motion-safe:animate-pulse-ring"
    aria-hidden="true"
  ></span>

  <svg viewBox="0 0 32 32" class="h-7 w-7" fill="#fff" aria-hidden="true">
    <path
      d="M16.01 3.2c-7.06 0-12.8 5.73-12.8 12.79 0 2.26.6 4.46 1.72 6.4L3.2 28.8l6.6-1.72a12.76 12.76 0 0 0 6.2 1.58h.01c7.06 0 12.79-5.74 12.79-12.8 0-3.42-1.33-6.63-3.75-9.05a12.7 12.7 0 0 0-9.04-3.6zm0 23.42h-.01a10.6 10.6 0 0 1-5.4-1.48l-.39-.23-4.02 1.05 1.07-3.92-.25-.4a10.6 10.6 0 0 1-1.62-5.65c0-5.86 4.77-10.63 10.64-10.63 2.84 0 5.5 1.11 7.51 3.12a10.56 10.56 0 0 1 3.11 7.52c0 5.87-4.77 10.62-10.63 10.62zm5.83-7.96c-.32-.16-1.89-.93-2.18-1.04-.29-.11-.5-.16-.72.16-.21.32-.82 1.04-1.01 1.25-.19.21-.37.24-.69.08-.32-.16-1.35-.5-2.57-1.59-.95-.85-1.59-1.9-1.78-2.22-.19-.32-.02-.49.14-.65.14-.14.32-.37.48-.56.16-.19.21-.32.32-.53.11-.21.05-.4-.03-.56-.08-.16-.72-1.73-.98-2.37-.26-.62-.52-.54-.72-.55l-.61-.01c-.21 0-.56.08-.85.4-.29.32-1.11 1.09-1.11 2.66 0 1.57 1.14 3.08 1.3 3.29.16.21 2.25 3.44 5.46 4.82.76.33 1.36.53 1.82.68.77.24 1.46.21 2.01.13.61-.09 1.89-.77 2.16-1.52.27-.74.27-1.38.19-1.51-.08-.13-.29-.21-.61-.37z"
    ></path>
  </svg>
</a>

<script>
  // Reveal the button after a slight scroll so it doesn't cover the hero CTAs.
  const fab = document.querySelector<HTMLElement>("[data-fab]");
  if (fab) {
    const reveal = () => {
      const show = window.scrollY > 240;
      fab.style.opacity = show ? "1" : "0";
      fab.style.transform = show ? "translateY(0)" : "translateY(1rem)";
      fab.style.pointerEvents = show ? "auto" : "none";
    };
    reveal();
    window.addEventListener("scroll", reveal, { passive: true });
  }
</script>
