---
import { site, navLinks, whatsappHref } from "../config";
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";

const year = new Date().getFullYear();
const hasLinkedIn = !site.linkedinUrl.includes("{{");
---

<footer class="relative mt-24 border-t border-border">
  <div class="container py-14">
    <div class="flex flex-col gap-10 md:flex-row md:items-start md:justify-between">
      <div class="max-w-sm">
        <a href="#home" class="inline-flex" aria-label="Ad-Ascent home">
          <Logo />
        </a>
        <p class="mt-4 text-sm leading-relaxed text-muted">{site.tagline}</p>
      </div>

      <div class="grid grid-cols-2 gap-10 sm:gap-16">
        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-muted">
            Navigate
          </h3>
          <ul class="mt-4 space-y-2.5 text-sm">
            {
              navLinks.map((l) => (
                <li>
                  <a
                    href={l.href}
                    class="text-muted transition-colors hover:text-text"
                  >
                    {l.label}
                  </a>
                </li>
              ))
            }
            <li>
              <a href="#contact" class="text-muted transition-colors hover:text-text">
                Contact Us
              </a>
            </li>
          </ul>
        </div>

        <div>
          <h3 class="text-xs font-semibold uppercase tracking-wider text-muted">
            Connect
          </h3>
          <ul class="mt-4 space-y-2.5 text-sm">
            <li>
              <a
                href={hasLinkedIn ? site.linkedinUrl : "#"}
                target={hasLinkedIn ? "_blank" : undefined}
                rel={hasLinkedIn ? "noopener noreferrer" : undefined}
                class="inline-flex items-center gap-2 text-muted transition-colors hover:text-text"
                aria-label="Ad-Ascent on LinkedIn"
              >
                <Icon name="linkedin" class="h-4 w-4" />
                LinkedIn
              </a>
            </li>
            <li>
              <a
                href={whatsappHref}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-muted transition-colors hover:text-text"
                aria-label="Chat with Ad-Ascent on WhatsApp"
              >
                <svg viewBox="0 0 32 32" class="h-4 w-4" fill="currentColor" aria-hidden="true">
                  <path
                    d="M16.01 3.2c-7.06 0-12.8 5.73-12.8 12.79 0 2.26.6 4.46 1.72 6.4L3.2 28.8l6.6-1.72a12.76 12.76 0 0 0 6.2 1.58h.01c7.06 0 12.79-5.74 12.79-12.8 0-3.42-1.33-6.63-3.75-9.05a12.7 12.7 0 0 0-9.04-3.6zm0 23.42h-.01a10.6 10.6 0 0 1-5.4-1.48l-.39-.23-4.02 1.05 1.07-3.92-.25-.4a10.6 10.6 0 0 1-1.62-5.65c0-5.86 4.77-10.63 10.64-10.63 2.84 0 5.5 1.11 7.51 3.12a10.56 10.56 0 0 1 3.11 7.52c0 5.87-4.77 10.62-10.63 10.62zm5.83-7.96c-.32-.16-1.89-.93-2.18-1.04-.29-.11-.5-.16-.72.16-.21.32-.82 1.04-1.01 1.25-.19.21-.37.24-.69.08-.32-.16-1.35-.5-2.57-1.59-.95-.85-1.59-1.9-1.78-2.22-.19-.32-.02-.49.14-.65.14-.14.32-.37.48-.56.16-.19.21-.32.32-.53.11-.21.05-.4-.03-.56-.08-.16-.72-1.73-.98-2.37-.26-.62-.52-.54-.72-.55l-.61-.01c-.21 0-.56.08-.85.4-.29.32-1.11 1.09-1.11 2.66 0 1.57 1.14 3.08 1.3 3.29.16.21 2.25 3.44 5.46 4.82.76.33 1.36.53 1.82.68.77.24 1.46.21 2.01.13.61-.09 1.89-.77 2.16-1.52.27-.74.27-1.38.19-1.51-.08-.13-.29-.21-.61-.37z"
                  ></path>
                </svg>
                WhatsApp
              </a>
            </li>
            <li>
              <a
                href={`mailto:${site.contactEmail}`}
                class="inline-flex items-center gap-2 text-muted transition-colors hover:text-text"
              >
                <Icon name="mail" class="h-4 w-4" />
                Email
              </a>
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div
      class="mt-12 flex flex-col gap-2 border-t border-border pt-6 text-xs text-muted sm:flex-row sm:items-center sm:justify-between"
    >
      <p>© {year} {site.name}. All rights reserved.</p>
      <p>Google Ads that turn search intent into booked jobs.</p>
    </div>
  </div>
</footer>
