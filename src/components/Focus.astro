---
import { focus } from "../config";
import SectionHeading from "./SectionHeading.astro";
import Icon from "./Icon.astro";
---

<section id="focus" class="relative py-10 sm:py-14">
  <div class="container">
    <SectionHeading overline={focus.overline} title={focus.title} align="center" />

    <div class="mt-14 grid gap-5 md:grid-cols-3">
      {
        focus.cards.map((card, i) => (
          <article
            data-reveal
            style={`--reveal-delay:${i * 90}ms`}
            class="group relative overflow-hidden rounded-[var(--radius-lg)] border border-border bg-surface/50 p-7 transition-all duration-300 hover:-translate-y-1 hover:border-primary/40 hover:shadow-[0_20px_50px_-24px_var(--glow-primary)]"
          >
            <div
              class="pointer-events-none absolute -right-10 -top-10 h-32 w-32 rounded-full bg-[radial-gradient(circle,var(--glow-primary),transparent_70%)] opacity-0 transition-opacity duration-300 group-hover:opacity-100"
              aria-hidden="true"
            />
            <span class="inline-grid h-12 w-12 place-items-center rounded-xl border border-border bg-bg/60 text-primary transition-colors duration-300 group-hover:border-primary/40">
              <Icon name={card.icon} class="h-6 w-6" />
            </span>
            <h3 class="mt-5 text-lg font-bold text-text">{card.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted">{card.body}</p>
          </article>
        ))
      }
    </div>

    <!-- Improve loop note connecting to How We Work -->
    <div
      data-reveal
      class="mx-auto mt-8 flex w-fit items-center gap-2.5 rounded-full border border-border bg-surface/40 px-4 py-2 text-sm text-muted"
    >
      <Icon name="spark" class="h-4 w-4 animate-[spin_9s_linear_infinite] text-accent" />
      <span>
        Then we <span class="font-semibold text-text">{focus.improveNote}</span> — a
        continuous loop, not a one-off.
      </span>
    </div>
  </div>
</section>
